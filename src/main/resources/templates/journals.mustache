<html>
<head>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/journal.css">
</head>
<body>
  <div class="wrapper">
    {{> sidebar}}
    <div class="main">
      <div class="header">
        <h1>仕訳一覧</h1>
      </div>
      <div class="content">

<form class="date-form">
  <div class="date-row">
    <div class="month-form-box">
      <!-- 開始日入力 -->
      <label for="fromDate">開始日:</label>
      <input
        type="date"
        id="fromDate"
        name="fromDate"
        class="input-date"
        required
        value="{{fromDate}}">
    </div>

    <div class="month-form-box">
      <!-- 終了日入力 -->
      <label for="toDate">最終日:</label>
      <input
        type="date"
        id="toDate"
        name="toDate"
        class="input-date"
        value="{{toDate}}">
    </div>
  </div>

  <button type="submit" class="submit-button">送信する</button>
  </form>
        <table class="table">
          <thead>
            <tr class="table-header">
              <th rowspan="2">日付</th>
              <th rowspan="2">摘要</th>
              <th class="debit-th" colspan="2">借方</th>
              <th class="credit-th" colspan="2">貸方</th>
            </tr>
            <tr class="table-header">
              <th class="debit-th">科目</th>
              <th class="debit-th">金額</th>
              <th class="credit-th">科目</th>
              <th class="credit-th">金額</th>
            </tr>
          </thead>
          <tbody>
            {{#journals}}
              <tr>
                <td>
                  {{#date}}{{date.value}}{{/date}}
                </td>
                <td class="txt-limit"
                    data-fulltext="{{#summary}}{{summary.value}}{{/summary}}">
                  {{#summary}}
                    {{summary.value}}
                  {{/summary}}
                  {{^summary}}
                  {{/summary}}
                </td>
                <td>
                  {{#debit}}{{debit.accountName.value}}{{/debit}}
                </td>
                <td class="money">
                  {{#debit}}{{debit.amount.value}}{{/debit}}
                </td>
                <td>
                  {{#credit}}{{credit.accountName.value}}{{/credit}}
                </td>
                <td class="money">
                  {{#credit}}{{credit.amount.value}}{{/credit}}
                </td>
              </tr>
            {{/journals}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <script src="/js/journal.js"></script>
</body>
</html>