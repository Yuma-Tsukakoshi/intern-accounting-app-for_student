<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <link rel="stylesheet" href="./css/style.css">
  <link rel="stylesheet" href="./css/pl.css">
  <title>損益計算書（PL）</title>
</head>
<body>
  <div class="wrapper pl-wrapper">
    {{> sidebar}}
    <div class="main">
      <div class="header">
        <h1>損益計算書（PL）</h1>
      </div>
      <div class="content">
        <form class="month-form">
          <div class="month-form-box">
            <label>対象範囲:</label>
            <div class="month-form-row">
              <input
                type="number"
                id="currentMonthFromYear"
                name="currentMonthFrom"
                min="1900"
                max="2100"
                required
                value="{{currentYearFrom}}"
              >
              <span>/</span>
              <input
                type="number"
                id="currentMonthFromMonth"
                name="currentMonthFrom"
                min="1"
                max="12"
                required
                value="{{currentMonthFromMonthVal}}"
              >
              <span> 〜 </span>
              <input
                type="number"
                id="currentMonthToYear"
                name="currentMonthTo"
                min="1900"
                max="2100"
                required
                value="{{currentYearTo}}"
              >
              <span>/</span>
              <input
                type="number"
                id="currentMonthToMonth"
                name="currentMonthTo"
                min="1"
                max="12"
                required
                value="{{currentMonthToMonthVal}}"
              >
            </div>
          </div>

          <div class="month-form-box">
            <label>比較範囲:</label>
            <div class="month-form-row">
              <input
                type="number"
                id="lastMonthFromYear"
                name="lastMonthFrom"
                min="1900"
                max="2100"
                value="{{lastYearFrom}}"
              >
              <span>/</span>
              <input
                type="number"
                id="lastMonthFromMonth"
                name="lastMonthFrom"
                min="1"
                max="12"
                value="{{lastMonthFromMonthVal}}"
              >
              <span> 〜 </span>
              <input
                type="number"
                id="lastMonthToYear"
                name="lastMonthTo"
                min="1900"
                max="2100"
                value="{{lastYearTo}}"
              >
              <span>/</span>
              <input
                type="number"
                id="lastMonthToMonth"
                name="lastMonthTo"
                min="1"
                max="12"
                value="{{lastMonthToMonthVal}}"
              >
            </div>
          </div>

          <button type="submit">送信する</button>
        </form>

        <p class="memo">単位：円</p>
<table class="table">
          <thead>
            <tr class="table-header">
              <th>集計科目</th>
              <th>科目</th>
              <th class="money">
                {{#lastMonthLabel}}{{lastMonthLabel}}{{/lastMonthLabel}}
                {{^lastMonthLabel}}比較月{{/lastMonthLabel}}
              </th>
              <th class="money">
                {{#currentMonthLabel}}{{currentMonthLabel}}{{/currentMonthLabel}}
                {{^currentMonthLabel}}対象月{{/currentMonthLabel}}
              </th>
              <th class="money">差額</th>
            </tr>
          </thead>
          <tbody>
            {{#pl}}
              {{!-- PROFIT --}}
              {{#profit}}
                <tr class="category-row">
                  <td>{{category.value}}</td>
                  <td></td>
                  <td class="money">
                    {{#lastAmount}}{{lastAmount}}{{/lastAmount}}
                    {{^lastAmount}}-{{/lastAmount}}
                  </td>
                  <td class="money">{{currentAmount}}</td>
                  <td class="money">
                    {{#catDiff}}{{catDiff}}{{/catDiff}}
                    {{^catDiff}}-{{/catDiff}}
                  </td>
                </tr>
                {{#subjects}}
                  <tr class="subject-row">
                    <td></td>
                    <td>{{accountName.value}}</td>
                    <td class="money">
                      {{#last}}
                        <span class="detail-trigger" data-subject="{{accountName.value}}" data-period="last">
                          {{last.amount}}
                        </span>
                      {{/last}}
                      {{^last}}-{{/last}}
                    </td>
                    <td class="money">
                      <span class="detail-trigger"
                            data-subject="{{accountName.value}}" data-period="current">
                        {{current.amount}}
                      </span>
                    </td>
                    <td class="money">
                      {{#diff}}{{diff}}{{/diff}}
                      {{^diff}}-{{/diff}}
                    </td>
                  </tr>
                {{/subjects}}
              {{/profit}}

              {{!-- LOSS --}}
              {{#loss}}
                <tr class="category-row">
                  <td>{{category.value}}</td>
                  <td></td>
                  <td class="money">
                    {{#lastAmount}}{{lastAmount}}{{/lastAmount}}
                    {{^lastAmount}}-{{/lastAmount}}
                  </td>
                  <td class="money">{{currentAmount}}</td>
                  <td class="money">
                    {{#catDiff}}{{catDiff}}{{/catDiff}}
                    {{^catDiff}}-{{/catDiff}}
                  </td>
                </tr>
                {{#subjects}}
                  <tr class="subject-row">
                    <td></td>
                    <td>{{accountName.value}}</td>
                    <td class="money">
                      {{#last}}
                          <span class="detail-trigger"
                                data-subject="{{accountName.value}}" data-period="last">
                            {{last.amount}}
                          </span>
                      {{/last}}
                      {{^last}}-{{/last}}
                    </td>
                    <td class="money">
                      <span class="detail-trigger"
                            data-subject="{{accountName.value}}" data-period="current">
                        {{current.amount}}
                      </span>
                    </td>
                    <td class="money">
                      {{#diff}}{{diff}}{{/diff}}
                      {{^diff}}-{{/diff}}
                    </td>
                  </tr>
                {{/subjects}}
              {{/loss}}

              {{!-- BENEFIT --}}
              {{#benefit}}
                <tr class="total-row">
                  <td>利益</td>
                  <td></td>
                  <td class="money">
                    {{#lastBenefit}}{{lastBenefit}}{{/lastBenefit}}
                    {{^lastBenefit}}-{{/lastBenefit}}
                  </td>
                  <td class="money">{{currentBenefit}}</td>
                  <td class="money">
                    {{#diffBenefit}}{{diffBenefit}}{{/diffBenefit}}
                    {{^diffBenefit}}-{{/diffBenefit}}
                  </td>
                </tr>
              {{/benefit}}
            {{/pl}}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- モーダル本体 -->
  <div id="modal" class="modal">
    <div class="modal-content">
      <span class="close-button">&times;</span>
      <h2 id="modal-title"></h2>
      <table class="table detail-table">
        <thead>
          <tr class="table-header">
            <th>日付</th><th>貸借</th><th>金額</th><th>摘要</th>
          </tr>
        </thead>
        <tbody id="modal-body"></tbody>
      </table>
    </div>
  </div>

  <!-- JS 用データ -->
  <script>
    window.PL_ENTRIES_BY_SUBJECT = {{{PL_ENTRIES_BY_SUBJECT}}};
  </script>
  <script src="/js/pl.js"></script>
</body>
</html>