<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <link rel="stylesheet" href="./css/style.css">
  <link rel="stylesheet" href="./css/pl-style.css">
  <title>損益計算書（PL）</title>
</head>
<body>
  <div class="wrapper pl-wrapper">
    {{> sidebar}}
    <div class="main">
      <div class="header">
        <h1>損益計算書（PL）</h1>
      </div>
      <div class="content">
        <form class="month-form" action="/pl" method="get">
            <div class="month-form-box">
                <input type="number" name="year" id="year" min="1900" max="2100" required  value="{{year}}">
                <span>/</span>
                <input type="number" name="month" id="month" min="1" max="12" required value="{{month}}">
           </div>
            <button type="submit">送信する</button>
        </form>
        <table class="table">
          <thead>
            <tr class="table-header">
              <th>集計科目</th>
              <th>科目</th>
              <th class="money">金額</th>
            </tr>
          </thead>
          <tbody>
          {{#pl}}
            {{!-- PROFIT のセクション --}}
            {{#profit}}
              <tr class="category-row">
                <td>{{category.value}}</td>
                <td></td>
                <td class="money">{{totalAmount}}</td>
              </tr>
              {{#subjects}}
                <tr class="subject-row">
                  <td></td>
                  <td>{{accountName.value}}</td>
                  <td class="money">
                    <span class="detail-trigger" data-subject="{{accountName.value}}">
                    {{totalAmount}}
                    </span>
                  </td>
                </tr>
              {{/subjects}}
            {{/profit}}

            {{!-- LOSS のセクション --}}
            {{#loss}}
              <tr class="category-row">
                <td>{{category.value}}</td>
                <td></td>
                <td class="money">{{totalAmount}}</td>
              </tr>
              {{#subjects}}
                <tr class="subject-row">
                  <td></td>
                  <td>{{accountName.value}}</td>
                  <td class="money">
                    <span class="detail-trigger" data-subject="{{accountName.value}}">
                    {{totalAmount}}
                    </span>
                  </td>
                </tr>
              {{/subjects}}
            {{/loss}}

            {{!-- 純利益 (BENEFIT) --}}
            <tr class="total-row">
              <td>利益</td>
              <td></td>
              <td class="money">{{benefit}}</td>
            </tr>
            {{/pl}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div id="modal" class="modal">
    <div class="modal-content">
      <span class="close-button">&times;</span>
      <h2>明細内訳</h2>
      <table class="table detail-table">
        <thead>
          <tr class="table-header">
            <th>日付</th>
            <th>貸借</th>
            <th>金額</th>
            <th>摘要</th>
          </tr>
        </thead>
        <tbody id="modal-detail-body">
        </tbody>
      </table>
    </div>
  </div>
  <script>
    window.PL_ENTRIES_BY_SUBJECT = {{{PL_ENTRIES_BY_SUBJECT}}};
  </script>
  <script src="/js/pl.js"></script>
</body>
</html>
